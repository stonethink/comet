{
  "assetsRoot": "assets",
  "manifestPath": "assets/manifest.json",
  "skillsRoots": {
    "en": "assets/skills",
    "zh": "assets/skills-zh"
  },
  "classicRuntime": {
    "entry": "domains/comet-classic/classic-cli.ts",
    "output": "assets/skills/comet/scripts/comet-runtime.mjs"
  },
  "allowedTopLevelEntries": [
    ".agents",
    ".claude",
    ".codegraph",
    ".codex",
    ".comet",
    ".git",
    ".gitattributes",
    ".github",
    ".gitignore",
    ".husky",
    ".idea",
    ".npmignore",
    ".prettierignore",
    ".prettierrc",
    ".tmp",
    "AGENTS.md",
    "app",
    "assets",
    "bin",
    "build.js",
    "CHANGELOG.md",
    "CLAUDE.md",
    "config",
    "CONTRIBUTING-zh.md",
    "CONTRIBUTING.md",
    "coverage",
    "dist",
    "docs",
    "domains",
    "eslint.config.js",
    "eval",
    "img",
    "LICENSE",
    "NEWS.md",
    "node_modules",
    "nul",
    "package-lock.json",
    "package.json",
    "platform",
    "pnpm-lock.yaml",
    "README-zh.md",
    "README.md",
    "scripts",
    "skills-lock.json",
    "test",
    "tsconfig.json",
    "vitest.config.ts"
  ],
  "sourceRoots": ["app", "domains", "platform"],
  "appModules": ["cli", "commands"],
  "domainModules": [
    "bundle",
    "comet-classic",
    "dashboard",
    "engine",
    "eval",
    "factory",
    "integrations",
    "skill"
  ],
  "platformModules": ["fs", "install", "paths", "process", "version"],
  "scriptModules": ["benchmark", "build", "install", "lib", "lint", "release"],
  "testRoots": ["test"]
}
