# Required for local and LangSmith eval runs.
ANTHROPIC_API_KEY=

# Optional Claude Code model override.
BENCH_CC_MODEL=
BENCH_CC_VERSION=latest

# Required only for eval/langsmith.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
TRACE_TO_LANGSMITH=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=comet-skill-eval
